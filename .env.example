FOUNDRY_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4.1
AZURE_PLAYWRIGHT_SERVICE_URL=wss://eastus.api.playwright.microsoft.com/playwrightworkspaces/<workspace-id>/browsers
AZURE_PLAYWRIGHT_SERVICE_ACCESS_TOKEN=<token>
BROWSER_CLI_MODE=playwright-cli
BROWSER_COMMAND_TIMEOUT_SECONDS=120
BROWSER_MAX_COMMANDS=24
BROWSER_MAX_OUTPUT_CHARS=15000
MCP_TIMEOUT_SECONDS=90
TOOLBOX_MCP_ENDPOINT=https://kumarmoh-7290-resource.services.ai.azure.com/api/projects/kumarmoh-7290/toolboxes/Mohit-toolbox/mcp?api-version=v1
TOOLBOX_TIMEOUT_SECONDS=60
